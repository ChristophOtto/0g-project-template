# Environment Variables Example
# Copy this file to .env and fill in your actual values.
# NEVER commit .env — it is gitignored by default.

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=myapp
# DB_USER=myuser
# DB_PASSWORD=

# ─── Auth / Secrets ───────────────────────────────────────────────────────────
# JWT_SECRET=
# SESSION_SECRET=

# ─── External APIs ────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# SENDGRID_API_KEY=
# OPENAI_API_KEY=

# ─── Cloud / Storage ──────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=
