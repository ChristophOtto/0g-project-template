#!/usr/bin/env bash
# pre-commit hook: scans staged files for secrets, API keys, and sensitive content
# Place in .githooks/pre-commit and run: git config core.hooksPath .githooks

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Colour

FOUND=0

echo "🔍 Scanning staged files for secrets..."

# ─── 1. Block sensitive file types ────────────────────────────────────────────
SENSITIVE_FILES=$(git diff --cached --name-only | grep -Ev '\.env\.example$' | grep -E \
  '\.(env|pem|key|p12|pfx|pkcs12|crt|cer|der|jks|keystore)$|^\.env(\..+)?$|credentials\.json$|secrets\.json$' \
  || true)

if [ -n "$SENSITIVE_FILES" ]; then
  echo -e "${RED}✗ BLOCKED: Sensitive file(s) staged for commit:${NC}"
  echo "$SENSITIVE_FILES" | sed 's/^/  /'
  FOUND=1
fi

# ─── 2. Scan file contents for secret patterns ────────────────────────────────
# Get all staged file contents (text files only)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

SECRET_PATTERNS=(
  # Generic patterns
  'password\s*=\s*["\x27][^"\x27]{4,}'
  'passwd\s*=\s*["\x27][^"\x27]{4,}'
  'secret\s*=\s*["\x27][^"\x27]{4,}'
  'api[_-]?key\s*=\s*["\x27][^"\x27]{4,}'
  'auth[_-]?token\s*=\s*["\x27][^"\x27]{4,}'
  'access[_-]?token\s*=\s*["\x27][^"\x27]{4,}'
  'private[_-]?key\s*=\s*["\x27][^"\x27]{4,}'

  # AWS
  'AKIA[0-9A-Z]{16}'
  'aws[_-]?secret[_-]?access[_-]?key\s*=\s*[A-Za-z0-9/+=]{40}'

  # GitHub
  'ghp_[0-9a-zA-Z]{36}'
  'github[_-]?token\s*=\s*["\x27][^"\x27]{36,}'

  # Stripe
  'sk_live_[0-9a-zA-Z]{24}'
  'pk_live_[0-9a-zA-Z]{24}'

  # Slack
  'xox[baprs]-[0-9A-Za-z\-]+'

  # Google
  'AIza[0-9A-Za-z\-_]{35}'
  'ya29\.[0-9A-Za-z\-_]+'

  # Private keys (PEM headers in content)
  '-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----'
  '-----BEGIN CERTIFICATE-----'
)

for FILE in $STAGED_FILES; do
  # Skip allowlisted files
  if echo "$FILE" | grep -Eq '\.env\.example$|gitleaks\.toml$|\.github/workflows/.*\.yml$|^\.githooks/.*'; then
    continue
  fi

  # Skip binary files
  if git show ":$FILE" 2>/dev/null | grep -qI ''; then
    for PATTERN in "${SECRET_PATTERNS[@]}"; do
      MATCH=$(git show ":$FILE" 2>/dev/null | grep -inE -- "$PATTERN" || true)
      if [ -n "$MATCH" ]; then
        echo -e "${RED}✗ BLOCKED: Possible secret found in ${YELLOW}$FILE${RED}:${NC}"
        echo "$MATCH" | head -3 | sed 's/^/  /'
        FOUND=1
        break
      fi
    done
  fi
done

# ─── 3. Result ────────────────────────────────────────────────────────────────
if [ "$FOUND" -eq 1 ]; then
  echo ""
  echo -e "${RED}🚫 Commit blocked. Remove secrets before committing.${NC}"
  echo "   Tip: use environment variables or a secrets manager instead."
  exit 1
fi

echo "✅ No secrets detected. Proceeding with commit."
exit 0
